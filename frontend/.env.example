# --- Puertos por defecto en este monorepo ---
# • Navegador (interfaz web):  http://localhost:3003   →  npm run dev:web
# • Backend API + Blinks:      http://localhost:3000   →  npm run dev
#
# NEXT_PUBLIC_API_URL debe ser la URL del BACKEND (3000), no la de Next (3003).
# En Vercel: URL pública del backend (Railway/Render) + CORS_ORIGIN en backend.
NEXT_PUBLIC_API_URL=http://localhost:3000

# URL pública de Blinks (si difiere del API, ej. CDN u otro host)
# Si no se define, se usa NEXT_PUBLIC_API_URL
# NEXT_PUBLIC_BLINKS_BASE_URL=https://tu-dominio.com

# Backend API (requerido en Vercel para formulario /piloto)
# NEXT_PUBLIC_API_URL=https://tu-backend.railway.app

# WhatsApp soporte (solo dígitos) — landing /piloto
# NEXT_PUBLIC_WA_SUPPORT=5214431234567

# Solana (frontend — wallet connect, devnet por defecto)
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# NEXT_PUBLIC_SOLANA_WS_URL=wss://api.devnet.solana.com
